# Model to serve — pulled automatically on first start, cached in ../data/ollama
# Change this to swap models without rebuilding the image
OLLAMA_MODEL=deepseek-coder-v2:lite

# Other options:
# OLLAMA_MODEL=llama3.1:8b          (smaller, faster, less accurate)
# OLLAMA_MODEL=codellama:13b         (good for code tasks)
# OLLAMA_MODEL=deepseek-coder:6.7b   (lightest deepseek option)
