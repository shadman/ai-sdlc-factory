# --- AGENTS API ---
# Where the agents-api service is reachable FROM this container:
#   Same machine (Docker):  http://host.docker.internal:9000
#   Remote deployment:      https://your-agents-api.yourdomain.com
AGENTS_API_URL=http://host.docker.internal:9000
