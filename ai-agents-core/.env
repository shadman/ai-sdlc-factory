# --- JIRA CONFIGURATION ---
JIRA_DOMAIN=yourdomain.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=atlassian_api_token_here

# --- GITHUB CONFIGURATION ---
# Use a Personal Access Token (PAT) with 'repo' scope
GITHUB_TOKEN=ghp_your_personal_access_token_here
GIT_USER_NAME="AI Factory Bot"
GIT_USER_EMAIL="ai-factory@yourcompany.com"

# --- INFRASTRUCTURE CONFIGURATION ---
# These match the service names in docker-compose.yml
REDIS_HOST=redis
REDIS_PORT=6379
OLLAMA_HOST=http://ollama:11434
PHOENIX_ENDPOINT=http://phoenix:4317

# --- MODEL CONFIGURATION ---
# Keeps the LLM from going rogue on your 16GB RAM
LLM_MODEL=deepseek-coder-v2:lite