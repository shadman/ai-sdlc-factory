# --- JIRA CONFIGURATION ---
JIRA_DOMAIN=https://shadmanjamil.atlassian.net
JIRA_USERNAME=shadman.jamil@gmail.com
JIRA_API_TOKEN=

# --- GITHUB CONFIGURATION ---
# Use a Personal Access Token (PAT) with 'repo' scope
GITHUB_TOKEN=
GIT_USER_NAME="shadman"
GIT_USER_EMAIL="shadman.jamil@gmail.com"

# --- PRODUCT REPO URLS ---
# Cloned at startup if not already present (required on Hugging Face)
BACKEND_REPO_URL=https://github.com/shadman/ai-sdlc-backend.git
FRONTEND_REPO_URL=https://github.com/shadman/ai-sdlc-frontend.git

# --- INFRASTRUCTURE CONFIGURATION ---
# Redis Cloud free tier: set REDIS_URL and leave REDIS_HOST/PORT blank
# Format: rediss://default:<password>@<host>:<port>
#REDIS_URL=
# Fallback if using a local Redis instead
REDIS_HOST=redis-19894.crce218.eu-central-1-1.ec2.cloud.redislabs.com
REDIS_PORT=19894
REDIS_PASSWORD=

OLLAMA_HOST=http://ollama:11434
PHOENIX_ENDPOINT=http://phoenix:4317

# --- MODEL CONFIGURATION ---
# Local (Ollama):
LLM_PROVIDER=ollama
LLM_MODEL=deepseek-coder-v2:lite
OLLAMA_HOST=http://ollama:11434

# Cloud — Hugging Face / remote deployment (uncomment one block):
#
# Option 1: Groq (free tier, fastest)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=
#
# Option 2: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

CREWAI_TRACING_ENABLED=true
